# Kubernetes
NAMESPACES=dev,staging,prod
RESCUE_IMAGE=registry.example.com/infrastructure/tanos-rescue:1.0

# Registry
REGISTRY_URL=registry.example.com
REGISTRY_USER=admin
REGISTRY_PASSWORD=secret
# REGISTRY_INSECURE=true

# Storage (local or s3)
STORAGE_TYPE=local
STORAGE_PATH=/data/tanos-backups

# S3 (if STORAGE_TYPE=s3)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=image-backups
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
